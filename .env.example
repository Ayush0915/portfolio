# ─── AI Chatbot (OpenRouter) ────────────────────────────────────────────────
# Get a free/paid key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Any model slug from https://openrouter.ai/models — e.g. meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=openrouter/free
# ─── Live Visitor Presence (Ably) ───────────────────────────────────────────
# Free tier key at https://ably.com — create an app, copy the "Root" API key
ABLY_API_KEY=your_ably_api_key_here

# ─── GitHub Contributions / Activity Widgets ────────────────────────────────
# Optional but recommended — raises GitHub API rate limits.
# Generate a classic token (no scopes needed for public data) at
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# ─── Contact Form (Resend) ──────────────────────────────────────────────────
# Get an API key at https://resend.com
RESEND_API_KEY=re_fztWj2Na_G5N7qZwTGDF43Y8KR8GYBRFc
# The destination email address where contact messages should be sent
CONTACT_TO_EMAIL=ayushbhadani0915@gmail.com

